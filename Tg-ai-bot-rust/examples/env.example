# Telegram
TELEGRAM_TOKEN=bot:123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_BOT_USERNAME=your_bot_username_without_at
TELEGRAM_GROUP_ID=-1001234567890

# Database (Postgres)
DATABASE_DSN=postgres://db_user:db_pass@db_host:5432/db_name

# Redis (for caching, rate limits, ephemeral state)
REDIS_URL=redis://:redis_password@redis_host:6379/

# Primary LLM / routing
OPENROUTER_API_KEY=your_openrouter_api_key

# Search provider keys (comma-separated for rotation)
BING_API_KEYS=bing_key_1,bing_key_2

# Image providers
STABLE_HORDE_KEY=your_stable_horde_key
HF_API_KEY=your_huggingface_api_key

# Optional provider fallbacks (comma-separated)
FALLBACK_LLM_KEYS=open_provider_key1,open_provider_key2

# App / runtime
PORT=3000
LOG_LEVEL=info

# Security / admin (seed values; also stored in DB in production)
INITIAL_ADMIN_TELEGRAM_ID=123456789